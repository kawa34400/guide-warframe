{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Guide Warframe Overlay",
  "version": "0.6.0",
  "identifier": "com.kawa34400.guide-warframe-overlay",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "https://guide-warframe.vercel.app",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Guide Warframe Overlay",
        "url": "https://guide-warframe.vercel.app/overlay",
        "width": 280,
        "height": 60,
        "minWidth": 200,
        "minHeight": 40,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "transparent": true,
        "visible": true,
        "center": false,
        "x": 20,
        "y": 20
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Game",
    "shortDescription": "Warframe overlay",
    "longDescription": "Lightweight always-on-top wrapper around guide-warframe.vercel.app — toggle with F8."
  },
  "plugins": {}
}
