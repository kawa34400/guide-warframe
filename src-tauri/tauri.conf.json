{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Guide Warframe Overlay",
  "version": "0.8.0",
  "identifier": "com.kawa34400.guide-warframe-overlay",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "https://guide-warframe.vercel.app",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "label": "cycles",
        "title": "Mondes",
        "url": "https://guide-warframe.vercel.app/bubble/cycles",
        "width": 180,
        "height": 95,
        "minWidth": 140,
        "minHeight": 60,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "transparent": true,
        "visible": true,
        "center": false,
        "x": 20,
        "y": 20
      },
      {
        "label": "missions",
        "title": "Missions",
        "url": "https://guide-warframe.vercel.app/bubble/missions",
        "width": 200,
        "height": 110,
        "minWidth": 160,
        "minHeight": 80,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "transparent": true,
        "visible": true,
        "center": false,
        "x": 20,
        "y": 180
      },
      {
        "label": "notes",
        "title": "Notes",
        "url": "https://guide-warframe.vercel.app/bubble/notes",
        "width": 220,
        "height": 150,
        "minWidth": 160,
        "minHeight": 80,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "transparent": true,
        "visible": true,
        "center": false,
        "x": 20,
        "y": 360
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Game",
    "shortDescription": "Warframe overlay",
    "longDescription": "Lightweight always-on-top wrapper around guide-warframe.vercel.app — toggle with F8."
  },
  "plugins": {}
}
